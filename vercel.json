{
  "headers": [
    {
      "source": "/static/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=180, must-revalidate"
        }
      ]
    },
    {
      "source": "/static/style.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=180, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/app.py" }
  ],
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ]
}
